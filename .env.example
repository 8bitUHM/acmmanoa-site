# Copy to .env for local development (never commit .env)
#
# Development:  copy this file, set DEBUG=1, run `docker compose up --build`
# Production:   same keys on the server with DEBUG=0 and strong passwords

# Django
SECRET_KEY=change-me
DEBUG=1
ALLOWED_HOSTS=127.0.0.1,localhost

# PostgreSQL (Docker Compose service name is "db" in dev and prod)
# If a password contains $, escape it as $$ in this file (Docker Compose rule)
POSTGRES_DB=acmmanoa
POSTGRES_USER=postgres
POSTGRES_PASSWORD=dev-password-change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432
